<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d1a">

    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_bar"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="-4dp" />

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#111128"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <!-- URL input -->
        <EditText
            android:id="@+id/url_input"
            android:layout_width="0dp"
            android:layout_height="49dp"
            android:layout_weight="1"
            android:background="#1e1e3a"
            android:hint="Enter URL..."
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:singleLine="true"
            android:textColor="#e0e0ff"
            android:textColorHint="#6666aa"
            android:textSize="12sp" />

        <!-- Go button -->
        <Button
            android:id="@+id/btn_go"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:background="#2244aa"
            android:padding="0dp"
            android:text="→"
            android:textColor="#ffffff"
            android:textSize="16sp" />
	<Button
            android:id="@+id/btn_refresh"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="2dp"
            android:background="#1e1e3a"
            android:padding="0dp"
            android:text="↺"
            android:textColor="#aaaaff"
            android:textSize="18sp" />

        <!-- Zoom Out -->
        <Button
            android:id="@+id/btn_zoom_out"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:background="#1e1e3a"
            android:padding="0dp"
            android:text="−"
            android:textColor="#aaaaff"
            android:textSize="20sp" />
	        <!-- Zoom In -->
        <Button
            android:id="@+id/btn_zoom_in"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="2dp"
            android:background="#1e1e3a"
            android:padding="0dp"
            android:text="+"
            android:textColor="#aaaaff"
            android:textSize="20sp" />

        <!-- Script toggle button - green when active, red when inactive -->
        <Button
            android:id="@+id/btn_toggle_script"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="2dp"
            android:background="#1a4a1a"
            android:padding="0dp"
            android:text="⚡"
            android:textColor="#44ff88"
            android:textSize="16sp" />
	<!-- PC button -->
         <Button
              android:id="@+id/btn_pc"
              android:layout_width="40dp"
              android:layout_height="wrap_content"
              android:layout_marginLeft="2dp"
              android:background="#1e1e3a"
              android:padding="0dp"
              android:text="🖥"
              android:textColor="#aaaaff"
              android:textSize="16sp" />

        <!-- Info panel button -->
        <Button
            android:id="@+id/btn_info"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="2dp"
            android:background="#1e1e3a"
            android:padding="0dp"
            android:text="ℹ"
            android:textColor="#aaaaff"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Info panel (hidden by default) -->
    <LinearLayout
        android:id="@+id/info_panel"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_above="@+id/bottom_bar"
        android:layout_alignParentRight="true"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp"
        android:orientation="vertical"
        android:background="#cc111128"
        android:padding="12dp"
        android:visibility="gone"
        android:elevation="16dp">

        <TextView
            android:id="@+id/info_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="URL: -"
            android:textColor="#aaaaff"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/info_script"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Script: Waiting..."
            android:textColor="#ffaa44"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/info_zoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zoom: %100"
            android:textColor="#aaaaff"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/info_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Ready"
            android:textColor="#44ff88"
            android:textSize="11sp" />

    </LinearLayout>

</RelativeLayout>
